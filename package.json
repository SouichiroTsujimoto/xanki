{
  "name": "xanki-monorepo",
  "private": true,
  "scripts": {
    "build:shared": "pnpm --filter @xanki/shared build",
    "build:ui": "pnpm --filter @xanki/ui typecheck",
    "setup:cloud": "bash scripts/setup-cloud.sh",
    "check:secrets": "bash scripts/check-dev-secrets.sh",
    "materialize:dev-vars": "bash scripts/materialize-dev-vars.sh",
    "setup:jj-workspace": "bash scripts/setup-jj-workspace.sh",
    "setup:jj-workspace:lite": "bash scripts/setup-jj-workspace.sh --lite",
    "check:design": "bash scripts/check-design-tokens.sh",
    "dev:cloud": "bash scripts/dev-cloud.sh",
    "dev:cloud:all": "bash scripts/dev-cloud.sh --desktop",
    "dev:cloud:mobile": "bash scripts/dev-cloud.sh --mobile",
    "dev:desktop": "pnpm --filter xanki tauri dev",
    "dev:mobile": "pnpm --filter @xanki/mobile dev",
    "dev:mobile:ios": "bash scripts/dev-ios.sh",
    "build:mobile": "pnpm --filter @xanki/mobile build",
    "build:mobile:ios": "pnpm --filter @xanki/mobile build:ios",
    "build:ios": "bash scripts/build-ios.sh",
    "build:web": "pnpm --filter @xanki/web build",
    "smoke:cloud": "pnpm --filter @xanki/web test:cloud",
    "test:auth": "pnpm --filter @xanki/web test:auth",
    "smoke:cloud:full": "bash scripts/dev-cloud.sh --smoke --skip-setup"
  }
}
