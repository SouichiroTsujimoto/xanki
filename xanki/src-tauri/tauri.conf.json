{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "xanki",
  "version": "0.1.0",
  "identifier": "com.souic.xanki",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "xanki",
        "width": 1280,
        "height": 840,
        "visible": false,
        "center": true,
        "theme": "Light",
        "backgroundColor": "#f5f5f7",
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 16,
          "y": 20
        }
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$APPLOCALDATA/**", "$RESOURCE/**"]
      }
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["xanki"]
      },
      "mobile": [
        {
          "scheme": ["xanki"]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["sidecar/ocr/xanki-ocr"]
  }
}
