# wrangler dev 用
#
# 正本: web/.dev.vars.op + 1Password CLI（リポジトリ管理・各 workspace で 1 回 materialize）
#   pnpm dev:cloud が scripts/with-dev-secrets.sh 経由で op run する
#   診断: pnpm check:secrets
#
# Fallback（1Password なし）: cp .dev.vars.example .dev.vars して平文を記入
# 1Password 利用時は .dev.vars 不要 — op run + wrangler.toml [secrets].required で process.env が Worker に渡る
# BETTER_AUTH_SECRET=  # 本番は wrangler secret put BETTER_AUTH_SECRET
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# AI_GATEWAY_TOKEN=
# CF_ACCOUNT_ID=
# AI_GATEWAY_ID=default
AI_MODEL=google-ai-studio/gemini-2.5-flash
# AI_MODEL=openai/gpt-4.1-mini                 # Unified Billing 代替
# AI_MODEL=workers-ai/@cf/meta/llama-3.3-70b-instruct-fp8-fast  # Workers AI 課金
# AI_MODEL=deepseek/deepseek-chat              # BYOK 必須（Unified Billing 非対応）
